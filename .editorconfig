root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
max_line_length = 120
ij_kotlin_allow_trailing_comma = false
ij_kotlin_allow_trailing_comma_on_call_site = false

# ktlint configuration -----------------------------------------------------
# Match the existing codebase style (no trailing commas, Composables exempt
# from camelCase naming, lenient class signature wrapping). These are wired
# at the editorconfig layer so both the Gradle plugin and any local IDE
# instance see the same rules.

# Composables are PascalCase by Compose convention.
ktlint_function_naming_ignore_when_annotated_with = Composable

# Disable rules whose default heuristics fight Compose-heavy KMP code.
ktlint_standard_class-signature = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_chain-method-continuation = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_property-wrapping = disabled
ktlint_standard_blank-line-before-declaration = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_filename = disabled
ktlint_standard_backing-property-naming = disabled
# Resource files generated by valkyrie + Compose Resources mix top-level
# decls in the same package without trailing comma settings — keep ktlint
# off these.
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
# Multi-line typed lambda parameters with stacked annotations — used by KMP
# expect/actual signatures bridging Compose @-annotations into iOS-native APIs.
ktlint_standard_function-type-modifier-spacing = disabled
ktlint_standard_annotation = disabled

# Generated/internal sources must not trip up ktlint.
[**/build/generated/**.{kt,kts}]
ktlint = disabled
[**/api/*.api]
ktlint = disabled

# iOS interop files often need `import platform.UIKit.*` to pull in ObjC
# category methods (navigationController, navigationItem, addChildViewController,
# etc.) that the cinterop layer exposes only as wildcard-importable extensions.
# Named imports for individual UIKit symbols don't reach those.
[**/iosMain/**.{kt,kts}]
ktlint_standard_no-wildcard-imports = disabled
